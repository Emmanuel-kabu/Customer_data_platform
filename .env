# Environment Configuration for Customer Data Platform
# Copy this file to .env and update values as needed

# ============================================================
# PostgreSQL Configuration
# ============================================================
POSTGRES_USER=cdp_admin
POSTGRES_PASSWORD=cdp_secure_pass_2026
POSTGRES_DB=customer_data_platform
POSTGRES_PORT=5432

# ============================================================
# MinIO Configuration (S3-Compatible Storage)
# ============================================================
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_secure_pass_2026
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET_RAW=raw-data
MINIO_BUCKET_PROCESSED=processed-data

# ============================================================
# Apache Airflow Configuration
# ============================================================
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__SQL_ALCHEMY_CONN=postgresql+psycopg2://cdp_admin:cdp_secure_pass_2026@postgres:5432/customer_data_platform
AIRFLOW__CORE__FERNET_KEY=ZmDfcTF7_60GrrS167zHxOHbMRyBkLYsEN_house_0FI=
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=False
AIRFLOW__WEBSERVER__EXPOSE_CONFIG=True
AIRFLOW__WEBSERVER__RBAC=True
AIRFLOW__SMTP__SMTP_HOST=smtp.gmail.com
AIRFLOW__SMTP__SMTP_PORT=587
AIRFLOW__SMTP__SMTP_STARTTLS=True
AIRFLOW__SMTP__SMTP_SSL=False
AIRFLOW__SMTP__SMTP_USER=your_email@gmail.com
AIRFLOW__SMTP__SMTP_PASSWORD=your_app_password
AIRFLOW__SMTP__SMTP_MAIL_FROM=your_email@gmail.com
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin_pass_2026
AIRFLOW_ADMIN_EMAIL=admin@cdp.local

# ============================================================
# Metabase Configuration
# ============================================================
MB_DB_TYPE=postgres
MB_DB_DBNAME=metabase
MB_DB_PORT=5432
MB_DB_USER=cdp_admin
MB_DB_PASS=cdp_secure_pass_2026
MB_DB_HOST=postgres
METABASE_PORT=3000

# ============================================================
# Slack Notifications (Optional)
# ============================================================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
SLACK_CHANNEL=#data-platform-alerts

# ============================================================
# Data Generator Configuration
# ============================================================
NUM_CUSTOMERS=1000
NUM_SALES_RECORDS=5000
NUM_PRODUCTS=50
